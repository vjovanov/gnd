grund_config_version = 1
project_name = "root"

[reference]
marker = "§"
trigger = "$$"
strict = true
require_grounding = false

[id]
format = "{kind}-{slug}"
section_separator = "."
section_heading_levels = "strict"
slug_pattern = "[a-z][a-z0-9-]*"

[[kinds]]
prefix = "GND"
title = "Reason for existence"

[[kinds]]
prefix = "GOAL"
title = "Outcomes the project is trying to achieve"

[[kinds]]
prefix = "FS"
folder = "docs/functional-spec"
title = "User-visible behavior and requirements"

[[kinds]]
prefix = "AR"
folder = "docs/architecture"
title = "System design and technical structure"

[[kinds]]
prefix = "DF"
folder = "docs/decisions/functional"
title = "Product behavior decisions and tradeoffs"

[[kinds]]
prefix = "DA"
folder = "docs/decisions/architectural"
title = "Architecture decisions and tradeoffs"

[[kinds]]
prefix = "E2E"
folder = "e2e/cases"
title = "Executable user scenarios"

[[kinds]]
prefix = "RM"
title = "Planned milestones and sequencing"

[scan]
include = ["docs"]
exclude = ["target", "node_modules", ".git", "dist", "build", ".venv"]
extensions = ["md", "rs", "go", "java", "kt", "ts", "tsx", "js", "py", "c", "cpp", "swift", "scala", "rb", "php", "cs"]
comment_prefixes = ["//", "#", ";", "--", "*", "/*"]
docstring_python = true
respect_gitignore = true

[output]
format = "text"
color = "auto"
relative_paths = true

[fmt.cross_refs]
enabled = true
anchor_format = "github"

[workspace]
members = ["apps/api"]
include_root = false
